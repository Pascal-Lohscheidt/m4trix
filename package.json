{
  "name": "core",
  "version": "0.0.0",
  "type": "module",
  "description": "This is root package.json for the @m4trix/core monorepo.",
  "packageManager": "pnpm@9.0.0",
  "author": "Pascal Lohscheidt",
  "license": "MIT",
  "scripts": {
    "get:turbo": "npm install -g turbo",
    "test": "vitest --typecheck",
    "test:coverage": "vitest run --coverage",
    "package:build": "turbo run @m4trix/core#build",
    "package:publish": "turbo run @m4trix/core#publish-package",
    "evals:build": "turbo run @m4trix/evals#build",
    "evals:publish": "turbo run @m4trix/evals#publish-package",
    "stream:build": "turbo run @m4trix/stream#build",
    "stream:publish": "turbo run @m4trix/stream#publish-package",
    "react:build": "turbo run @m4trix/react#build",
    "react:publish": "turbo run @m4trix/react#publish-package",
    "ui:build": "turbo run @m4trix/ui#build",
    "ui:publish": "turbo run @m4trix/ui#publish-package",
    "release:check:core": "jiti scripts/check-package-scope.ts core",
    "release:check:evals": "jiti scripts/check-package-scope.ts evals",
    "release:check:stream": "jiti scripts/check-package-scope.ts stream",
    "release:check:react": "jiti scripts/check-package-scope.ts react",
    "release:check:ui": "jiti scripts/check-package-scope.ts ui",
    "release:bump:core": "jiti scripts/bump-and-tag.ts core",
    "release:bump:evals": "jiti scripts/bump-and-tag.ts evals",
    "release:bump:stream": "jiti scripts/bump-and-tag.ts stream",
    "release:bump:react": "jiti scripts/bump-and-tag.ts react",
    "release:bump:ui": "jiti scripts/bump-and-tag.ts ui"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@vitest/coverage-v8": "^3.1.2",
    "jsdom": "^26.1.0",
    "prettier": "^3.0.0",
    "turbo": "^2.5.2",
    "vitest": "^3.1.2",
    "jiti": "^1.21.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
